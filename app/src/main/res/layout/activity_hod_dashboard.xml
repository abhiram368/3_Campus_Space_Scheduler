<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back,"
                        android:textColor="@color/white"
                        android:alpha="0.8"
                        android:textAppearance="?attr/textAppearanceBody1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOD Dashboard"
                        android:textColor="@color/white"
                        android:textAppearance="?attr/textAppearanceHeadline5"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/glass_warm_bg"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:padding="10dp"
                        app:tint="@color/accent_blue" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Navigation Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Escalated Requests -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnEscalatedRequests"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/glass_warm_bg"
                        android:padding="20dp"
                        android:gravity="start|center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            app:tint="@color/accent_blue"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Escalated"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textAppearance="?attr/textAppearanceBody1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Requests"
                            android:textColor="@color/text_secondary"
                            android:textAppearance="?attr/textAppearanceCaption" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Live Status -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnLiveStatus"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/glass_warm_bg"
                        android:padding="20dp"
                        android:gravity="start|center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="@color/accent_teal"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textAppearance="?attr/textAppearanceBody1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textColor="@color/text_secondary"
                            android:textAppearance="?attr/textAppearanceCaption" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- View Schedule -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewSchedule"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/glass_warm_bg"
                        android:padding="20dp"
                        android:gravity="start|center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="#D3B13E"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textAppearance="?attr/textAppearanceBody1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Schedule"
                            android:textColor="@color/text_secondary"
                            android:textAppearance="?attr/textAppearanceCaption" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Approval History -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnApprovalHistory"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/glass_warm_bg"
                        android:padding="20dp"
                        android:gravity="start|center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="#5FEF68"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Approval"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textAppearance="?attr/textAppearanceBody1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="History"
                            android:textColor="@color/text_secondary"
                            android:textAppearance="?attr/textAppearanceCaption" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Insights Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_warm_bg"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total bookings this week"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="?attr/textAppearanceCaption" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="42 Bookings"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textAppearance="?attr/textAppearanceHeadline5" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BOOK BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBook"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Book Resource"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceBody1"
                app:backgroundTint="#D7C02D"
                app:cornerRadius="32dp"
                app:elevation="4dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>