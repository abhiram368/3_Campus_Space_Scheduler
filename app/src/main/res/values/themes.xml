    <style name="Theme.CampusScheduler" parent="Theme.Material3.Light">
        <item name="colorPrimary">@color/blue_500</item>
        <item name="colorPrimaryContainer">#dbeafe</item>
        <item name="colorOnPrimaryContainer">@color/blue_900</item>
        <item name="colorSurface">@color/slate_50</item>
